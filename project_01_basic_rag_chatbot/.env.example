# =============================================
# Environment Variables – RAG Chatbot
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Path to your PDF file
PDF_PATH=your_document.pdf

# Ollama model name (default: mistral)
OLLAMA_MODEL=mistral

# Number of chunks to retrieve (default: 3)
RETRIEVER_K=3

# Chunk size for text splitting (default: 500)
CHUNK_SIZE=500

# Chunk overlap (default: 50)
CHUNK_OVERLAP=50
